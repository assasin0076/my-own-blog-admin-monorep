generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Stuff {
  id          String   @id @default(uuid())
  label       String   @unique
  description String
  tags        String
  repoLink    String
  viewLink    String?
  createdAt   DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  nick      String   @unique
  password  String
  createdAt DateTime @default(now())
}
