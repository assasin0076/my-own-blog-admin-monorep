{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@backend/*": ["./src/*"]
    },
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "Bundler",

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.build.tsbuildinfo",

    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,

    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
