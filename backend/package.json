{
  "name": "@my-own-blog-admin-pannel/backend",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register src/index.ts",
    "build": " rimraf ./dist && tsc -b ./tsconfig.json",
    "start": "node ./dist/index.js",
    "types": "tsc --noEmit --project ./tsconfig.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslintcache ."
  },
  "dependencies": {
    "@trpc/server": "^11.16.0",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2 || ^6.0.0"
  }
}
