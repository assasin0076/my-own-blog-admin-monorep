{
  "name": "@my-own-blog-admin-pannel/backend",
  "private": true,
  "version": "0.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "require": "./dist/router/index.js",
      "import": "./dist/router/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch -r tsconfig-paths/register src/index.ts",
    "build": " rimraf ./dist && tsc -b ./tsconfig.json",
    "start": "node ./dist/index.js",
    "types": "tsc --noEmit --project ./tsconfig.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslintcache .",
    "trpc:create": "tsx scripts/trpc-create.tsx"
  },
  "dependencies": {
    "@trpc/server": "^11.16.0",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2 || ^6.0.0"
  }
}
