{
  "name": "@my-own-blog-admin-pannel/backend",
  "private": true,
  "version": "0.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/*/index.d.ts"
      ]
    }
  },
  "scripts": {
    "dev": "tsx watch -r tsconfig-paths/register src/index.ts .env",
    "build": "rimraf ./dist ./node_modules/.tmp/tsconfig.build.tsbuildinfo && tsc -b ./tsconfig.build.json",
    "start": "node ./dist/index.js",
    "types": "tsc --noEmit --project ./tsconfig.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslintcache .",
    "trpc:create": "tsx scripts/trpc-create.tsx",
    "pmigrate": "prisma migrate dev",
    "pgenerate": "prisma generate",
    "ppull": "prisma db pull",
    "pstudio": "prisma studio",
    "prepare": "pnpm pgenerate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@trpc/server": "^11.16.0",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "superjson": "^2.2.6",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "prettier": "^3.8.1",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
