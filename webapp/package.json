{
  "name": "@my-own-blog-admin-pannel/webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslintcache .",
    "stylelint": "stylelint --cache --cache-location ./node_modules/.cache/.stylelintcache \"src/**/*.scss\"",
    "stylecheck": "sass --update -q ./src:./node_modules/.cache/.stylecheckcache",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "types": "tsc --noEmit --project ./tsconfig.json && tsc --noEmit --project ./tsconfig.app.json && tsc --noEmit --project ./tsconfig.node.json",
    "types-new": "tsc --noEmit --project ./tsconfig.json",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "@my-own-blog-admin-pannel/backend": "workspace:*",
    "@tanstack/react-query": "^5.97.0",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "date-fns": "^4.1.0",
    "formik": "^2.4.9",
    "modern-normalize": "^3.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.14.1",
    "sass": "^1.99.0",
    "superjson": "^2.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "3.8.1",
    "stylelint": "^17.8.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-scss": "1.0.0-security",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.4",
    "yup": "^1.7.1"
  }
}
